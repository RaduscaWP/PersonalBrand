# Never commit real secrets.
# Resend sandbox sender (onboarding@resend.dev) can only send to the email address
# attached to your Resend account. For real inbox delivery, verify a domain in
# Resend and use an address from that domain, for example hello@yourdomain.com.
RESEND_API_KEY=
CONTACT_TO_EMAIL=grozavradustefan@gmail.com
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME=Radu Portfolio
SITE_URL=https://personal-brand-phi-tan.vercel.app
# Keep localhost origins local-only. Production should use the deployed site origin.
CONTACT_ALLOWED_ORIGINS=https://personal-brand-phi-tan.vercel.app,http://localhost:3000
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=3600
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
